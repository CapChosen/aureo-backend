# ════════════════════════════════════════════════════════
# Áureo — Variables de entorno
# Copiar como .env y completar los valores reales.
# NUNCA subir .env al repositorio.
# ════════════════════════════════════════════════════════

# Entorno: "development" activa logs y CORS permisivo
#          "production" activa CORS estricto (solo aureo.cl)
NODE_ENV=development

# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=3000

# ── Supabase ─────────────────────────────────────────────
# https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=sb_secret_...

# ── Anthropic Claude ──────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Finnhub (datos de mercado) ────────────────────────────
# https://finnhub.io/dashboard → API Key
FINNHUB_API_KEY=

# ── NewsAPI (noticias financieras) ────────────────────────
# https://newsapi.org → Get API Key
NEWS_API_KEY=

# ── Stripe (pagos) ───────────────────────────────────────
# https://dashboard.stripe.com/apikeys
# Usar sk_test_... en development, sk_live_... en production
STRIPE_SECRET_KEY=sk_test_...
